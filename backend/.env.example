# ─────────────────────────────────────────────
#  OUTREACH PIPELINE — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Stage 1: Ocean.io ─────────────────────────
OCEAN_API_KEY=your_ocean_io_api_key_here
# Ocean.io API base: https://api.ocean.io/v1
# Sign up at ocean.io using your company email (hello@mayurdev.site)

# ── Stage 2: Prospeo ─────────────────────────
PROSPEO_API_KEY=your_prospeo_api_key_here
# Prospeo API base: https://api.prospeo.io
# Sign up at app.prospeo.io/api

# ── Stage 3: Eazyreach ───────────────────────
EAZYREACH_API_KEY=your_eazyreach_api_key_here
# Eazyreach API base: https://api.eazyreach.app
# Credits provided by Vocallabs — share account details with them

# ── Stage 4: Brevo ───────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
# Brevo API base: https://api.brevo.com/v3
# Sender email MUST match your verified sender
BREVO_SENDER_EMAIL=hello@mayurdev.site
BREVO_SENDER_NAME=Mayur | Dev Partnerships

# ── Pipeline Config ───────────────────────────
# Max lookalike companies to fetch from Ocean.io (avoid overusing credits)
OCEAN_MAX_RESULTS=10
# Max decision-makers per company from Prospeo
PROSPEO_MAX_CONTACTS_PER_DOMAIN=3
# Concurrency for email resolution (be gentle on Eazyreach)
EAZYREACH_CONCURRENCY=2
# Rate limit delay between Eazyreach requests (ms)
EAZYREACH_DELAY_MS=1200
# Dry-run mode: set to "true" to skip actually sending emails via Brevo
DRY_RUN=false
